{
  "name": "hazman5540-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create hazman5540db",
    "db:migrate": "wrangler d1 execute hazman5540db --file=src/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute hazman5540db --local --file=src/db/schema.sql",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.20",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.59.1"
  }
}
