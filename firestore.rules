rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Attendance students — admin manages, student reads own data
    match /attendance_students/{studentId} {
      allow read, write: if true;
    }

    // Attendance admins — admin login validation
    match /attendance_admins/{adminId} {
      allow read, write: if true;
    }

    // Attendance logs — students create/read, admin reads all
    match /attendance_logs/{logId} {
      allow read, write: if true;
    }

    // Leave requests — students create, admin manages
    match /leave_requests/{requestId} {
      allow read, write: if true;
    }

    // Admin settings — admin reads/writes office config
    match /admin_settings/{settingId} {
      allow read, write: if true;
    }

    // Photo collection countries — public read, upload adds images
    match /countries/{countryId} {
      allow read, write: if true;
    }

    // Family members — open CRUD
    match /family_members/{memberId} {
      allow read, write: if true;
    }

    // Office shirt sizes — open CRUD
    match /office_baju/{entryId} {
      allow read, write: if true;
    }

    // E-Claim collection (new) — open CRUD
    match /eclaim_claims/{claimId} {
      allow read, write: if true;
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
